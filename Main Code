# ============================================================
# STEP 2 — TEXT PREPROCESSING
# ============================================================

stop_words = ENGLISH_STOP_WORDS  # sklearn's built-in English stopwords

def preprocess(text):
    """
    Full preprocessing pipeline:
      1. Lowercase
      2. Remove punctuation & numbers
      3. Tokenize (simple whitespace split)
      4. Remove stopwords
    Note: sklearn's TF-IDF vectorizer handles stemming internally
    via its analyzer. We do manual preprocessing here for clarity.
    """
    # 1. Lowercase
    text = text.lower()

    # 2. Remove punctuation and digits
    text = re.sub(r'[^a-z\s]', '', text)

    # 3. Tokenize (split on whitespace)
    tokens = text.split()

    # 4. Remove stopwords
    tokens = [t for t in tokens if t not in stop_words]

    return " ".join(tokens)

df['Cleaned_Review'] = df['Review'].apply(preprocess)

print("\n" + "=" * 60)
print("STEP 2 — TEXT PREPROCESSING")
print("=" * 60)
print("Steps applied: lowercase → remove punctuation → tokenize → remove stopwords")
print("\nOriginal  →  Cleaned (first 5 rows):\n")
for _, row in df.head(5).iterrows():
    print(f"  Original : {row['Review']}")
    print(f"  Cleaned  : {row['Cleaned_Review']}\n")


# ============================================================
# STEP 3 — FEATURE EXTRACTION
# ============================================================

X = df['Cleaned_Review']
y = df['Sentiment']

# Split before vectorizing to avoid data leakage
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42, stratify=y
)

print("=" * 60)
print("STEP 3 — FEATURE EXTRACTION")
print("=" * 60)

# ── 3a. Bag of Words ─────────────────────────────────────────
bow_vectorizer = CountVectorizer()
X_train_bow    = bow_vectorizer.fit_transform(X_train)
X_test_bow     = bow_vectorizer.transform(X_test)

print(f"Bag of Words matrix shape  : {X_train_bow.shape}")
print(f"  (rows=train reviews, cols=unique words)")

# ── 3b. TF-IDF ───────────────────────────────────────────────
tfidf_vectorizer = TfidfVectorizer()
X_train_tfidf    = tfidf_vectorizer.fit_transform(X_train)
X_test_tfidf     = tfidf_vectorizer.transform(X_test)

print(f"TF-IDF matrix shape        : {X_train_tfidf.shape}")


# ============================================================
# STEP 4 — MODEL TRAINING
# ============================================================

print("\n" + "=" * 60)
print("STEP 4 — MODEL TRAINING (Logistic Regression)")
print("=" * 60)

# ── Train on BoW features ────────────────────────────────────
model_bow = LogisticRegression(max_iter=1000, random_state=42)
model_bow.fit(X_train_bow, y_train)
print("Logistic Regression trained on Bag-of-Words features ✓")

# ── Train on TF-IDF features ─────────────────────────────────
model_tfidf = LogisticRegression(max_iter=1000, random_state=42)
model_tfidf.fit(X_train_tfidf, y_train)
print("Logistic Regression trained on TF-IDF features       ✓")


# ============================================================
# STEP 5 — MODEL EVALUATION
# ============================================================

print("\n" + "=" * 60)
print("STEP 5 — MODEL EVALUATION")
print("=" * 60)

# ── BoW Results ──────────────────────────────────────────────
y_pred_bow = model_bow.predict(X_test_bow)
acc_bow    = accuracy_score(y_test, y_pred_bow)

print(f"\n--- Bag-of-Words Model ---")
print(f"Accuracy : {acc_bow * 100:.1f}%")
print("\nClassification Report:")
print(classification_report(y_test, y_pred_bow, target_names=['Negative', 'Neutral', 'Positive']))

# ── TF-IDF Results ───────────────────────────────────────────
y_pred_tfidf = model_tfidf.predict(X_test_tfidf)
acc_tfidf    = accuracy_score(y_test, y_pred_tfidf)

print(f"\n--- TF-IDF Model ---")
print(f"Accuracy : {acc_tfidf * 100:.1f}%")
print("\nClassification Report:")
print(classification_report(y_test, y_pred_tfidf, target_names=['Negative', 'Neutral', 'Positive']))

# ── Best Model Summary ───────────────────────────────────────
best = "TF-IDF" if acc_tfidf >= acc_bow else "Bag-of-Words"
print(f"Best performing model: {best}")


